# Copy to .env for local development.
# Do not commit real values.

APP_ENV=development
RUNTIME_MODE=mock
DRY_RUN=true
REQUIRE_HUMAN_APPROVAL=true
ALLOW_EXTERNAL_SUBMISSION=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_application_agent

# Optional integrations for local/private use only.
# Leave blank for public/mock runs.
OPENAI_API_KEY=

# Google Sheets / Drive IDs must be private runtime values.
GOOGLE_SHEETS_STAGING_ID=
GOOGLE_SHEETS_PRODUCTION_ID=
GOOGLE_DRIVE_STAGING_FOLDER_ID=
GOOGLE_DRIVE_PRODUCTION_FOLDER_ID=
GOOGLE_DRIVE_GENERATED_MATERIALS_FOLDER_ID=

# Optional local service account path.
# Do not commit service account files.
GOOGLE_APPLICATION_CREDENTIALS=
